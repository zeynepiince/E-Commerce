{
  "version": "1.0",
  "description": "Multi-turn dialogue scenarios for end-to-end ZERA chatbot evaluation (intent + reply correctness). Rule-based path; no OpenAI.",
  "metrics": [
    "turn_intent_accuracy",
    "turn_reply_accuracy",
    "scenario_success_rate",
    "grounding_stock_db",
    "grounding_sizes_product",
    "grounding_policy",
    "grounding_prices"
  ],
  "scenarios": [
    {
      "id": "dlg_01",
      "name": "EN tshirt → size S → stock",
      "description": "Product search then size and stock follow-ups on last suggested product.",
      "lang": "en",
      "turns": [
        {
          "user": "I want to buy tshirt",
          "expect": {
            "intent": "product_search",
            "source": "product_search",
            "min_suggested_products": 1,
            "product_name_contains": "tshirt",
            "reply_contains": ["$"],
            "reply_not_contains": ["Happy to help. You can ask about product recommendations"],
            "grounding": {"prices_match_products": true}
          }
        },
        {
          "user": "does it have Size S",
          "expect": {
            "intent": "product_followup",
            "source": "product_followup",
            "reply_contains": ["size S", "available"],
            "reply_not_contains": ["Happy to help. You can ask about product recommendations", "Could you add a bit more detail"],
            "grounding": {"sizes_match_product": true, "requested_size": "S"}
          }
        },
        {
          "user": "stock?",
          "expect": {
            "intent": "product_followup",
            "source": "product_followup",
            "reply_contains": ["in stock"],
            "reply_not_contains": ["out of stock", "Happy to help. You can ask about product recommendations"],
            "grounding": {"stock_matches_db": true}
          }
        }
      ]
    },
    {
      "id": "dlg_02",
      "name": "TR tişört → S beden → stok",
      "description": "Turkish multi-turn product follow-up.",
      "lang": "tr",
      "turns": [
        {
          "user": "tshirt almak istiyorum",
          "expect": {
            "intent": "product_search",
            "source": "product_search",
            "min_suggested_products": 1,
            "reply_contains": ["$"],
            "grounding": {"prices_match_products": true}
          }
        },
        {
          "user": "S beden var mı",
          "expect": {
            "intent": "product_followup",
            "source": "product_followup",
            "reply_contains": ["S", "beden"],
            "reply_not_contains": ["Memnuniyetle yardımcı olurum"],
            "grounding": {"sizes_match_product": true, "requested_size": "S"}
          }
        },
        {
          "user": "stokta mı",
          "expect": {
            "intent": "product_followup",
            "source": "product_followup",
            "reply_contains": ["stokta"],
            "reply_not_contains": ["stokta yok"],
            "grounding": {"stock_matches_db": true}
          }
        }
      ]
    },
    {
      "id": "dlg_03",
      "name": "EN product search then cheaper refinement",
      "description": "Follow-up refines previous product search with cheaper constraint.",
      "lang": "en",
      "turns": [
        {
          "user": "show me wireless headphones",
          "expect": {
            "intent": "product_search",
            "min_suggested_products": 1,
            "reply_not_contains": ["Happy to help. You can ask about product recommendations"],
            "grounding": {"prices_match_products": true}
          }
        },
        {
          "user": "show cheaper ones",
          "expect": {
            "intent": "product_search",
            "min_suggested_products": 1,
            "reply_not_contains": ["Happy to help. You can ask about product recommendations"]
          }
        }
      ]
    },
    {
      "id": "dlg_04",
      "name": "EN shipping policy",
      "lang": "en",
      "turns": [
        {
          "user": "how long does shipping take",
          "expect": {
            "intent": "shipping",
            "source": "rule_based",
            "reply_contains": ["ship", "day"],
            "reply_not_contains": ["Here are some good options"],
            "grounding": {"policy_intent": "shipping"}
          }
        }
      ]
    },
    {
      "id": "dlg_05",
      "name": "TR return policy",
      "lang": "tr",
      "turns": [
        {
          "user": "iade koşulları neler",
          "expect": {
            "intent": "returns",
            "source": "rule_based",
            "reply_contains": ["iade"],
            "reply_not_contains": ["Here are some good options", "Şunlara göz atabilirsin"],
            "grounding": {"policy_intent": "returns"}
          }
        }
      ]
    },
    {
      "id": "dlg_06",
      "name": "EN order status guest",
      "description": "Without login, order lookup should ask to sign in.",
      "lang": "en",
      "user_id": null,
      "turns": [
        {
          "user": "where is my order",
          "expect": {
            "intent": "order_status",
            "source": "order_lookup",
