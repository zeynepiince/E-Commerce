        },
        {
          "user": "order #20",
          "expect": {
            "intent": "order_status",
            "source": "order_lookup",
            "reply_contains": ["#20", "pending"],
            "reply_not_contains": ["sign in"]
          }
        }
      ]
    },
    {
      "id": "dlg_08",
      "name": "EN stock question without product context",
      "description": "Isolated stock utterance must not hallucinate a product answer.",
      "lang": "en",
      "turns": [
        {
          "user": "stock?",
          "expect": {
            "intent": "general",
            "reply_not_contains": ["is in stock", "is currently out of stock", "units available"]
          }
        }
      ]
    },
    {
      "id": "dlg_09",
      "name": "EN greeting",
      "lang": "en",
      "turns": [
        {
          "user": "hello",
