# InfinityFree — File Manager'da site köküne .env adıyla kaydedin (htdocs/)
# Yerel E-Commerce/.env dosyanızdaki IYZICO_* değerlerini aşağıya yapıştırın.

# ── InfinityFree MySQL (Control Panel → MySQL Databases) ──
DB_HOST=sqlXXX.infinityfree.com
DB_PORT=3306
DB_NAME=if0_XXXXXXX_zera
DB_USER=if0_XXXXXXX
DB_PASS=your_mysql_password
DB_CHARSET=utf8mb4

FORCE_HTTPS=true
IMPORT_PRODUCTS_ENABLED=false

ADMIN_EMAIL=your@email.com

# ── iyzico sandbox (localhost .env ile aynı anahtarlar) ──
IYZICO_API_KEY=sandbox-xxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxx
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_USD_TRY_RATE=34.0
IYZICO_DEFAULT_IDENTITY=11111111111
CHECKOUT_DEMO_MODE=false

MAIL_ENABLED=false
