# Bu dosyayı .env olarak kopyalayın ve değerleri ortamınıza göre düzenleyin.
# .env dosyası git ile takip edilmez (.gitignore içinde).

# Veritabanı bağlantısı (TCP)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chatbotv2_db
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4

# Alternatif: Unix socket üzerinden bağlantı (MAMP, Homebrew, vb.)
# DB_SOCKET tanımlandığında DB_HOST/DB_PORT yok sayılır.
# Örnek MAMP socket'i:
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# OpenAI API (chatbot için, opsiyonel)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
