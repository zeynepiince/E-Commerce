# Bu dosyayı .env olarak kopyalayın ve değerleri ortamınıza göre düzenleyin.
# cp .env.example .env
# .env dosyası git ile takip edilmez (.gitignore içinde).

# ── Veritabanı (TCP) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chatbotv2_db
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4

# Alternatif: Unix socket (MAMP, Homebrew). Tanımlandığında DB_HOST/DB_PORT yok sayılır.
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# ── OpenAI (chatbot — opsiyonel, ücretli) ─────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chatbot experiment mode: ab2 | ab | ai | rule
# CHATBOT_EXPERIMENT_MODE=ab2

# ── Admin ─────────────────────────────────────────────────────────────────────
# Giriş yapmış bu e-posta admin_orders.php ve import_products.php (tarayıcı) erişir.
ADMIN_EMAIL=admin@example.com

# ── OAuth (Google / Facebook) ───────────────────────────────────────────────────
# Her iki provider için ID + secret dolu olmalı; aksi halde giriş butonları devre dışı kalır.
# Google: Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Facebook: developers.facebook.com → App → Settings → Basic
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Opsiyonel; boş bırakılırsa otomatik: http(s)://host/.../oauth_callback.php
OAUTH_REDIRECT_URI=http://localhost:8888/chatbotv2/E-Commerce/oauth_callback.php

# ── Ürün import (yerel geliştirme) ────────────────────────────────────────────
# Canlı sunucuda tanımlamayın (varsayılan: kapalı).
IMPORT_PRODUCTS_ENABLED=true

# ── Oturum & rate limit ─────────────────────────────────────────────────────
# Canlıda HTTPS arkasında FORCE_HTTPS=true önerilir.
# FORCE_HTTPS=true
# LOGIN_RATE_LIMIT_MAX=8
# LOGIN_RATE_LIMIT_WINDOW=900
# LOGIN_RATE_LIMIT_LOCK=900

# ── E-posta (karşılama + şifre sıfırlama) ───────────────────────────────────
# Şifre sıfırlama için MAIL_ENABLED=true ve SMTP_* zorunlu.
MAIL_ENABLED=false
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=ZERA
MAIL_SITE_NAME=ZERA
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls

# ── iyzico ödeme (sandbox) ────────────────────────────────────────────────────
# Anahtarlar: https://sandbox-merchant.iyzipay.com
# IYZICO_API_KEY=sandbox-xxxxxxxx
# IYZICO_SECRET_KEY=sandbox-xxxxxxxx
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# IYZICO_USD_TRY_RATE=34.0
# IYZICO_DEFAULT_IDENTITY=11111111111
